theorem jacobi_triple_product (hq : ‚ÄĖq‚ÄĖ < 1) (hw : w ‚Č† 0) :
    lhs w q = rhs w q := by
  -- Apply tendsto_nhds_unique to the partial identity
  have h_id : ‚ąÄ n, (‚ąŹ k ‚ąą Finset.range n, (1 - q^(2*(k+1)))) * phi n w q =
              ‚ąĎ k ‚ąą Finset.Icc (-(n:‚Ą§)) n, (-1)^k * w^(2*k) * q^(k^2) * B n k q :=
    triple_partial
  exact tendsto_nhds_unique
    (by rw [‚Üź funext h_id]; exact partial_lhs_tendsto hq hw)
    (partial_rhs_tendsto hq hw)
