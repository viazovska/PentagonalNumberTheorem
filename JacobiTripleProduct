/-! ## Section 3: Jacobi Triple Product (Theorem 25) -/
/-- **Theorem 25, Jacobi Triple Product (Source)**: For all `w ‚Č† 0` and `|q| < 1`:
`‚ąŹ_{k‚Č•1} (1 - q^{2k})(1 - q^{2k-1}w¬≤)(1 - q^{2k-1}w‚ĀĽ¬≤) = ‚ąĎ_{k=-‚ąě}^{‚ąě} (-1)^k w^{2k} q^{k¬≤}`.
The source document outlines a proof via the auxiliary function
`ŌÜ‚āô(w,q) = ‚ąŹ_{k=1}^n (1-q^{2k-1}w¬≤)(1-q^{2k-1}w‚ĀĽ¬≤)` and a functional equation
`ŌÜ‚āô(qw,q) = ŌÜ‚āô(w,q) ¬∑ (1-q^{2n+1}w¬≤)/(-qw¬≤+q^{2n})`, then analyzes the Laurent
coefficients `A‚āô,‚āĖ(q)` satisfying a recurrence and takes `n ‚Üí ‚ąě`.
This analytic result generalizes the Pentagonal Number Theorem (which is the special
case `w = 1`, `q = x^{1/2}`). Its full formalization would require convergence
analysis of infinite products, which is beyond the scope of this combinatorial
formalization. -/



open scoped BigOperators
open Complex Filter Topology

namespace JacobiTripleProduct

variable {w q : ‚Ąā}

/-- The left-hand side: triple product over positive integers. -/
noncomputable def lhs (w q : ‚Ąā) : ‚Ąā :=
  ‚ąŹ' k : ‚Ąē, (1 - q^(2*(k+1))) *
            (1 - q^(2*(k+1) - 1) * w^2) *
            (1 - q^(2*(k+1) - 1) * w^(-2 : ‚Ą§))

/-- The right-hand side: bi-infinite theta-like series. -/
noncomputable def rhs (w q : ‚Ąā) : ‚Ąā :=
  ‚ąĎ' k : ‚Ą§, (-1)^k * w^(2*k) * q^(k^2)


  /-- Partial product ŌÜ‚āô(w,q) = ‚ąŹ_{k=1}^n (1 - q^{2k-1} w¬≤)(1 - q^{2k-1} w^{-2}). -/
noncomputable def phi (n : ‚Ąē) (w q : ‚Ąā) : ‚Ąā :=
  ‚ąŹ k ‚ąą Finset.range n,
    (1 - q^(2*(k+1) - 1) * w^2) * (1 - q^(2*(k+1) - 1) * w^(-2 : ‚Ą§))

  /-- Partial product ŌÜ‚āô(w,q) = ‚ąŹ_{k=1}^n (1 - q^{2k-1} w¬≤)(1 - q^{2k-1} w^{-2}). -/
noncomputable def phi (n : ‚Ąē) (w q : ‚Ąā) : ‚Ąā :=
  ‚ąŹ k ‚ąą Finset.range n,
    (1 - q^(2*(k+1) - 1) * w^2) * (1 - q^(2*(k+1) - 1) * w^(-2 : ‚Ą§))

/-- Closed form for the coefficient A‚āô,‚āĖ from eqn (5), for 0 ‚Č§ k ‚Č§ n.
    Defined for all k ‚ąą ‚Ą§ via symmetry A‚āô,‚āĖ = A‚āô,‚āč‚āĖ. -/
noncomputable def A (n : ‚Ąē) (k : ‚Ą§) (q : ‚Ąā) : ‚Ąā :=
  if h : k.natAbs ‚Č§ n then
    q^(k^2) / (‚ąŹ s ‚ąą Finset.Ico 1 (n+1), (1 - q^(2*s))) *
      (‚ąŹ s ‚ąą Finset.Ico (n - k.natAbs + 1) (n+1), (1 - q^(2*s))) *
      (‚ąŹ s ‚ąą Finset.Ico (n + k.natAbs + 1) (2*n+1), (1 - q^(2*s)))
  else 0

