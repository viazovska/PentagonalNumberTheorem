lemma A_recurrence (n : ‚Ąē) (k : ‚Ą§) (hk : 1 ‚Č§ k) (hkn : k ‚Č§ n) (q : ‚Ąā)
    (hq : ‚ąÄ s ‚ąą Finset.Ico 1 (2*n+1), (1 : ‚Ąā) - q^(2*s) ‚Č† 0) :
    A n k q * (1 - q^(2*n + 2*k)) = A n (k-1) q * q^(2*k - 1) * (1 - q^(2*n - 2*k + 2)) := by
