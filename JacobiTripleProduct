lemma triple_partial (n : ‚Ąē) (hw : w ‚Č† 0) :
    (‚ąŹ k ‚ąą Finset.range n, (1 - q^(2*(k+1)))) * phi n w q =
    ‚ąĎ k ‚ąą Finset.Icc (-(n:‚Ą§)) n, (-1)^k * w^(2*k) * q^(k^2) * B n k q := by
  sorry

noncomputable def B (n : ‚Ąē) (k : ‚Ą§) (q : ‚Ąā) : ‚Ąā :=
  (‚ąŹ s ‚ąą Finset.Ico (n - k.natAbs + 1) (n+1), (1 - q^(2*s))) *
    (‚ąŹ s ‚ąą Finset.Ico (n + k.natAbs + 1) (2*n+1), (1 - q^(2*s)))


